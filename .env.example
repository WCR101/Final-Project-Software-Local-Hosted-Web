# ═══════════════════════════════════════════════════════
# Athenaeum Library Management System – Environment Config
# ═══════════════════════════════════════════════════════
# Copy this file to .env and customize for your environment

# ───── DATABASE ─────
POSTGRES_USER=libraryuser
POSTGRES_PASSWORD=librarypassword
POSTGRES_DB=librarydb
DB_PORT=5432

# ───── BACKEND ─────
BACKEND_PORT=4000
NODE_ENV=production

# ───── FRONTEND ─────
FRONTEND_PORT=8080

# ───── POSTGREST (Auto-generated REST API) ─────
POSTGREST_PORT=3001

# ───── DOCKER ─────
# Leave these as-is for most setups
COMPOSE_PROJECT_NAME=library-system
